# ==========================================
# AI智能求职辅导平台 - 环境变量配置模板
# 使用方式：复制为 .env 并填入真实值
# ==========================================

# MySQL数据库密码
MYSQL_PASSWORD=your_mysql_password_here

# Redis密码（如无密码则留空）
REDIS_PASSWORD=

# JWT签名密钥（请修改为随机字符串）
JWT_SECRET=your_jwt_secret_key_change_this

# DeepSeek API密钥（必填）
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
